# Public values: safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only value. Never prefix this variable with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Edge Function secrets are configured with `supabase secrets set`, not exposed to Next.js.
# RESEND_API_KEY=re_your_resend_api_key
# EMAIL_FROM=Combat Sensei <notifications@your-verified-domain.example>
# APP_URL=https://your-production-domain.example
# OUTBOX_WORKER_TOKEN=replace-with-at-least-32-random-characters
